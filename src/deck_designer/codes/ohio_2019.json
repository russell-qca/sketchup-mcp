{
  "code_name": "2019 Ohio Residential Code",
  "base_code": "IRC 2018",
  "jurisdiction": "Ohio",
  "effective_date": "2019-01-01",
  "description": "Ohio Residential Code for deck construction, based on IRC 2018",

  "loads": {
    "dead_load_psf": 10,
    "live_load_psf": 40,
    "total_load_psf": 50,
    "snow_load_psf": 25,
    "notes": "Dead load includes deck framing and decking. Live load per IRC Table R301.5"
  },

  "frost_depth": {
    "depth_inches": 32,
    "notes": "Ohio frost depth per IRC Figure R301.2(1). May vary by county."
  },

  "footings": {
    "min_diameter_inches": 12,
    "min_depth_inches": 32,
    "soil_bearing_capacity_psf": 1500,
    "concrete_strength_psi": 2500,
    "notes": "Footings must extend below frost line. Soil bearing capacity assumes typical soil - verify with soils report."
  },

  "posts": {
    "max_height_feet": 8,
    "sizes": {
      "4x4": {
        "max_load_lbs": 4000,
        "max_beam_span_ft": 6
      },
      "4x6": {
        "max_load_lbs": 6000,
        "max_beam_span_ft": 8
      },
      "6x6": {
        "max_load_lbs": 8000,
        "max_beam_span_ft": 12
      }
    },
    "notes": "Post sizes based on tributary area and load. For ground-level decks (<30in), 4x4 typically sufficient."
  },

