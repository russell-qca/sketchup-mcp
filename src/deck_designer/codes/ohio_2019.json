  "decking": {
    "5/4x6": {
      "max_joist_spacing_inches": 16,
      "perpendicular_to_joists": true
    },
    "2x6": {
      "max_joist_spacing_inches": 24,
      "perpendicular_to_joists": true,
      "diagonal_45deg_max_spacing": 16
    },
    "notes": "Decking must be pressure-treated or naturally decay-resistant. Fasteners must be corrosion-resistant."
  },

  "fasteners": {
    "joist_to_beam": {
      "type": "joist hanger or (2) 10d nails toe-nailed each side",
      "notes": "Joist hangers preferred for positive connection"
    },
    "beam_to_post": {
      "type": "approved post cap or through-bolted",
      "min_bolt_diameter": "1/2 inch"
    },
    "decking": {
      "type": "10d nails or #8 screws, minimum",
      "spacing": "2 fasteners per joist crossing"
    }
  },

  "ground_level_deck": {
    "max_height_inches": 30,
    "railing_required": false,
    "notes": "Decks not more than 30 inches above grade do not require guardrails per IRC R312.1. Steps require handrails if 4 or more risers."
  }
}
